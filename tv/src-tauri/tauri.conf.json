{
	"$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
	"productName": "ITTVOne",
	"version": "0.1.0",
	"identifier": "com.alecortiz.ittvone",
	"build": {
		"frontendDist": "../dist",
		"devUrl": "http://localhost:5173",
		"beforeDevCommand": "npm run dev",
		"beforeBuildCommand": "npm run build"
	},
	"app": {
		"windows": [
			{
				"title": "ITTVOne",
				"resizable": false,
				"decorations": false,
				"fullscreen": true
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"createUpdaterArtifacts": true,
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
